{
  "expo": {
    "name": "PharmaERP Mobile",
    "slug": "pharma-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pharmamobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "expo-sqlite",
      "@sentry/react-native",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow PharmaERP to take selfies and visit photos."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow PharmaERP to use your location for attendance and visit verification."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow PharmaERP to attach receipts and product photos."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow PharmaERP to use Face ID to unlock."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "http://localhost:5000",
      "apiVersion": "v1",
      "enableMediaUpload": false,
      "enableVisitPhotos": false,
      "enableExpenseReceipts": false,
      "enableProductMedia": false
    }
  }
}
