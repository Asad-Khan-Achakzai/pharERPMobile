{
  "expo": {
    "name": "PharmaERP Mobile",
    "slug": "pharma-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pharmamobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["location"],
        "NSLocationWhenInUseUsageDescription": "PharmaERP uses your location for attendance check-in and visit verification.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "PharmaERP shares your location with your manager while you are checked in, including when the app is in the background.",
        "NSLocationAlwaysUsageDescription": "PharmaERP shares your location with your manager while you are checked in, including when the app is in the background."
      },
      "bundleIdentifier": "com.asadkhanachakzie.pharmamobileapp"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.asadkhanachakzie.pharmamobileapp",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
 "plugins": [
  "expo-router",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/splash-icon.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    }
  ],
  "expo-secure-store",
  "expo-sqlite",
  [
    "expo-camera",
    {
      "cameraPermission": "Allow PharmaERP to take selfies and visit photos."
    }
  ],
  [
    "expo-location",
    {
      "locationWhenInUsePermission": "PharmaERP uses your location for attendance check-in and visit verification.",
      "locationAlwaysAndWhenInUsePermission": "PharmaERP shares your location with your manager while you are checked in, including when the app is in the background.",
      "locationAlwaysPermission": "PharmaERP shares your location with your manager while you are checked in, including when the app is in the background.",
      "isIosBackgroundLocationEnabled": true,
      "isAndroidBackgroundLocationEnabled": true,
      "isAndroidForegroundServiceEnabled": true
    }
  ],
  [
    "expo-image-picker",
    {
      "photosPermission": "Allow PharmaERP to attach receipts and product photos."
    }
  ],
  "@react-native-community/datetimepicker",
  [
    "expo-notifications",
    {
      "icon": "./assets/images/icon.png",
      "color": "#2563eb",
      "defaultChannel": "default"
    }
  ]
],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiVersion": "v1",
      "enableMediaUpload": false,
      "enableVisitPhotos": false,
      "enableExpenseReceipts": false,
      "enableProductMedia": false,
      "router": {},
      "eas": {
        "projectId": "fabc0660-de67-4083-8cc1-3e5342912e3c"
      }
    }
  }
}
